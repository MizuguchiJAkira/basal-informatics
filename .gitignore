node_modules/

# Stage 7 — local PTAD cache, refreshed by cron from PTAD downloads.
# The cache contains parcel-level CAD data and is regenerated on
# every refresh; not source of truth, never commit it.
valuation/_ptad_cache/

# Local pytest / coverage artifacts
.pytest_cache/
.coverage
htmlcov/
